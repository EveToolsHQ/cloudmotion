{
  "name": "cloudmotion",
  "version": "0.3.0",
  "description": "Cloudmotion Node.js SDK and CLI.",
  "author": "EveTools (https://evetools.app)",
  "homepage": "https://cloudmotion.dev",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "cloudmotion": "./dist/bin/cloudmotion.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "cloudmotion",
    "remotion",
    "video",
    "sdk",
    "cli"
  ],
  "license": "MIT"
}
